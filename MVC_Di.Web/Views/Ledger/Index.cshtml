@model LedgerIndexViewModel
@{
    ViewData["Title"] = "我的記帳";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4">我的分類</h2>
                <p class="text-muted">分類為個人專屬，只會出現在你自己的下拉選單。</p>

                <form asp-action="AddCategory" method="post" class="mb-4" id="add-category-form">
                    @Html.AntiForgeryToken()
                    <div class="text-danger mb-3 d-none" id="add-category-error"></div>
                    <div class="mb-3">
                        <label asp-for="NewCategory.Name" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="NewCategory.Name" class="form-control" id="new-category-name" />
                            <button type="submit" class="btn btn-outline-secondary">新增</button>
                        </div>
                        <span asp-validation-for="NewCategory.Name" class="text-danger"></span>
                    </div>
                </form>

                @if (Model.Categories.Count == 0)
                {
                    <div class="alert alert-warning" id="category-empty-state">請先建立至少一個分類。</div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mb-4" id="category-list">
                        @foreach (var category in Model.Categories)
                        {
                            <span class="badge rounded-pill border text-dark bg-light">@category</span>
                        }
                    </div>
                }

                @if (Model.Categories.Count == 0)
                {
                    <div class="d-flex flex-wrap gap-2 mb-4 d-none" id="category-list"></div>
                }

                <hr />

                <h1 class="h3">新增支出</h1>
                <p class="text-muted">目前登入者：@Model.DisplayName</p>
                <div class="alert alert-light border">
                    <div><strong>累計支出：</strong> @Model.TotalAmount.ToString("C0")</div>
                    <div><strong>筆數：</strong> @Model.Records.Count</div>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="NewRecord.Category" class="form-label"></label>
                        <select asp-for="NewRecord.Category" class="form-select" id="record-category-select">
                            <option value="">請選擇分類</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category">@category</option>
                            }
                        </select>
                        <span asp-validation-for="NewRecord.Category" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewRecord.Description" class="form-label"></label>
                        <input asp-for="NewRecord.Description" class="form-control"/>
                        <span asp-validation-for="NewRecord.Description" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewRecord.Amount" class="form-label"></label>
                        <input asp-for="NewRecord.Amount" class="form-control"/>
                        <span asp-validation-for="NewRecord.Amount" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewRecord.SpendDate" class="form-label"></label>
                        <input asp-for="NewRecord.SpendDate" class="form-control"/>
                        <span asp-validation-for="NewRecord.SpendDate" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">新增記錄</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">支出清單</h2>

                @if (Model.Records.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">目前還沒有支出資料。</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead>
                            <tr>
                                <th>日期</th>
                                <th>分類</th>
                                <th>用途</th>
                                <th class="text-end">金額</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var record in Model.Records)
                            {
                                <tr>
                                    <td>@record.SpendDate.ToString("yyyy-MM-dd")</td>
                                    <td>@record.Category</td>
                                    <td>@record.Description</td>
                                    <td class="text-end">@record.Amount.ToString("C0")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial"/>
    <script>
        const addCategoryForm = document.getElementById("add-category-form");
        const newCategoryNameInput = document.getElementById("new-category-name");
        const addCategoryError = document.getElementById("add-category-error");
        const categoryList = document.getElementById("category-list");
        const categoryEmptyState = document.getElementById("category-empty-state");
        const recordCategorySelect = document.getElementById("record-category-select");

        newCategoryNameInput?.addEventListener("keydown", function (event) {
            if (event.key === "Enter") {
                event.preventDefault();
                addCategoryForm?.requestSubmit();
            }
        });

        function renderCategories(categories) {
            if (!categoryList) {
                return;
            }

            categoryList.classList.remove("d-none");
            categoryList.replaceChildren();

            categories.forEach(function (category) {
                const badge = document.createElement("span");
                badge.className = "badge rounded-pill border text-dark bg-light";
                badge.textContent = String(category ?? "").trim();
                categoryList.appendChild(badge);
            });
        }

        function renderCategoryOptions(categories, selectedCategory) {
            if (!recordCategorySelect) {
                return;
            }

            recordCategorySelect.replaceChildren();

            const defaultOption = document.createElement("option");
            defaultOption.value = "";
            defaultOption.textContent = "請選擇分類";
            recordCategorySelect.appendChild(defaultOption);

            categories.forEach(function (category) {
                const option = document.createElement("option");
                option.value = String(category ?? "").trim();
                option.textContent = String(category ?? "").trim();
                recordCategorySelect.appendChild(option);
            });

            recordCategorySelect.value = selectedCategory;
        }

        addCategoryForm?.addEventListener("submit", async function (event) {
            event.preventDefault();

            addCategoryError?.classList.add("d-none");
            if (addCategoryError) {
                addCategoryError.textContent = "";
            }

            const formData = new FormData(addCategoryForm);

            const response = await fetch(addCategoryForm.action, {
                method: "POST",
                body: formData,
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            });

            const result = await response.json();

            if (!response.ok) {
                if (addCategoryError) {
                    addCategoryError.textContent = result.errorMessage ?? "新增分類失敗";
                    addCategoryError.classList.remove("d-none");
                }
                return;
            }

            const categories = Array.isArray(result.categories) ? result.categories : [];
            const selectedCategory = String(result.categoryName ?? "").trim();

            renderCategories(categories);

            if (categoryEmptyState) {
                categoryEmptyState.classList.add("d-none");
            }

            renderCategoryOptions(categories, selectedCategory);

            addCategoryForm.reset();
            newCategoryNameInput?.focus();
        });
    </script>
}
